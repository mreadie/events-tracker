---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Colorado Sports Events Tracker" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Track Colorado sports events across all major and minor teams" />
    <link rel="icon" type="image/svg+xml" href="/events-tracker/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="bg-primary/90 backdrop-blur-md border-b border-secondary/20 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-12">
          <!-- Logo -->
          <a href="/events-tracker/" class="flex items-center gap-2 text-accent font-bold text-lg">
            <span class="text-secondary">⚡</span> CO Sports and Shows
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-5">
            <a href="/events-tracker/" class="text-text-primary hover:text-secondary font-medium text-sm transition-colors">Home</a>
            <a href="/events-tracker/primary" class="text-text-primary hover:text-secondary font-medium text-sm transition-colors">Big 4</a>
            <a href="/events-tracker/secondary" class="text-text-primary hover:text-secondary font-medium text-sm transition-colors">All the Rest</a>
            <a href="/events-tracker/sports" class="text-text-primary hover:text-secondary font-medium text-sm transition-colors">By Sport</a>
            <a href="/events-tracker/music" class="text-text-primary hover:text-secondary font-medium text-sm transition-colors">Music</a>
            <a href="/events-tracker/tracker" class="text-secondary hover:text-secondary/80 font-semibold text-sm border border-secondary rounded-md px-3 py-1 transition-all hover:bg-secondary/10">My Tracker</a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden text-text-primary hover:text-secondary">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile Nav -->
        <div id="mobile-menu" class="hidden md:hidden pb-3">
          <div class="flex flex-col gap-2">
            <a href="/events-tracker/" class="text-text-primary hover:text-secondary font-medium text-sm">Home</a>
            <a href="/events-tracker/primary" class="text-text-primary hover:text-secondary font-medium text-sm">Big 4</a>
            <a href="/events-tracker/secondary" class="text-text-primary hover:text-secondary font-medium text-sm">All the Rest</a>
            <a href="/events-tracker/sports" class="text-text-primary hover:text-secondary font-medium text-sm">By Sport</a>
            <a href="/events-tracker/music" class="text-text-primary hover:text-secondary font-medium text-sm">Music</a>
            <a href="/events-tracker/tracker" class="text-secondary hover:text-secondary/80 font-semibold text-sm">My Tracker</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-primary/80 backdrop-blur-sm border-t border-secondary/10 mt-4">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex flex-col md:flex-row items-center justify-between gap-3">
          <div class="flex items-center gap-4">
            <span class="text-secondary font-bold text-sm">⚡ CO Sports and Shows</span>
            <span class="text-text-secondary text-xs hidden md:inline">|</span>
            <span class="text-text-secondary text-xs hidden md:inline">Your Colorado sports companion</span>
          </div>
          <div class="flex items-center gap-4 text-xs">
            <a href="/events-tracker/primary" class="text-text-secondary hover:text-secondary transition-colors">Big 4</a>
            <a href="/events-tracker/secondary" class="text-text-secondary hover:text-secondary transition-colors">All the Rest</a>
            <a href="/events-tracker/sports" class="text-text-secondary hover:text-secondary transition-colors">By Sport</a>
            <a href="/events-tracker/tracker" class="text-text-secondary hover:text-secondary transition-colors">Tracker</a>
          </div>
        </div>
        <div class="border-t border-secondary/10 mt-3 pt-3 text-center text-text-secondary text-[11px]">
          &copy; {new Date().getFullYear()} Colorado Sports Events Tracker
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
