---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Tracker - Colorado Sports Events Tracker">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-accent mb-3">My Tracker</h1>
      <p class="text-text-secondary text-lg">Track your attendance and upcoming events across all Colorado sports teams.</p>
    </div>

    <!-- Placeholder for React component -->
    <div class="bg-surface-card border border-secondary/20 rounded-xl p-8">
      <div class="text-center py-12">
        <div class="text-5xl mb-4">📋</div>
        <h2 class="text-xl font-bold text-accent mb-3">Attendance Tracker Coming Soon</h2>
        <p class="text-text-secondary max-w-lg mx-auto mb-6">
          This section will feature an interactive React component where you can track games attended, 
          plan upcoming events, and set reminders for your favorite Colorado sports teams.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-2xl mx-auto">
          <div class="bg-surface-light rounded-lg p-4">
            <div class="text-2xl font-bold text-secondary">0</div>
            <div class="text-text-secondary text-sm mt-1">Games Attended</div>
          </div>
          <div class="bg-surface-light rounded-lg p-4">
            <div class="text-2xl font-bold text-secondary">0</div>
            <div class="text-text-secondary text-sm mt-1">Upcoming Events</div>
          </div>
          <div class="bg-surface-light rounded-lg p-4">
            <div class="text-2xl font-bold text-secondary">0</div>
            <div class="text-text-secondary text-sm mt-1">Teams Following</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
