---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="Colorado Avalanche - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/primary" class="hover:text-secondary">Big 4</a>
      <span class="mx-2">/</span>
      <span class="text-accent">Colorado Avalanche</span>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-accent mb-1">Colorado Avalanche</h1>
    <p class="text-text-secondary text-sm mb-6">NHL • Ball Arena</p>
    <a href="https://www.nhl.com/avalanche" target="_blank" rel="noopener" class="inline-block mb-6">
      <img src="https://a.espncdn.com/i/teamlogos/nhl/500/col.png" alt="Colorado Avalanche logo" class="w-16 h-16 object-contain hover:scale-110 transition-transform" />
    </a>
    <TeamFullSchedule teamKey="avalanche" seasonStartMonth="October" client:load />
  </section>
</Layout>
