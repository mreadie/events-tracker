---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="Colorado Rapids - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/secondary" class="hover:text-secondary">All the Rest</a>
      <span class="mx-2">/</span>
      <span class="text-accent">Colorado Rapids</span>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-accent mb-1">Colorado Rapids</h1>
    <p class="text-text-secondary text-sm mb-6">MLS • Dick's Sporting Goods Park</p>
    <TeamFullSchedule teamKey="rapids" client:load />
  </section>
</Layout>
