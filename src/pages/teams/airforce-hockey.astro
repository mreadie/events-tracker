---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="Air Force Falcons Hockey - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/sports/hockey" class="hover:text-secondary">Hockey</a>
      <span class="mx-2">/</span>
      <span class="text-accent">Air Force Falcons Hockey</span>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-accent mb-1">Air Force Falcons Hockey</h1>
    <p class="text-text-secondary text-sm mb-6">Atlantic Hockey (NCAA D1) • Cadet Ice Arena</p>
    <TeamFullSchedule teamKey="airforce_hockey" seasonStartMonth="October" client:load />
  </section>
</Layout>
