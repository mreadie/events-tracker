---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="Air Force Falcons Football - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/secondary" class="hover:text-secondary">All the Rest</a>
      <span class="mx-2">/</span>
      <span class="text-accent">Air Force Falcons Football</span>
    </nav>
    <div class="flex items-center gap-2 sm:gap-3 mb-1 flex-wrap">
      <h1 class="text-xl sm:text-2xl md:text-3xl font-bold text-accent">Air Force Falcons Football</h1>
      <a href="https://goairforcefalcons.com/sports/football" target="_blank" rel="noopener">
        <img src="https://a.espncdn.com/i/teamlogos/ncaa/500/2005.png" alt="Air Force Falcons logo" class="w-10 h-10 object-contain hover:scale-110 transition-transform" />
      </a>
    </div>
    <p class="text-text-secondary text-sm mb-6">Mountain West (NCAAF) • Falcon Stadium</p>
    <TeamFullSchedule teamKey="airforce_football" seasonStartMonth="August" client:load />
  </section>
</Layout>
