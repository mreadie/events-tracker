---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="CSU Rams Basketball - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/secondary" class="hover:text-secondary">All the Rest</a>
      <span class="mx-2">/</span>
      <span class="text-accent">CSU Rams Basketball</span>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-accent mb-1">CSU Rams Basketball</h1>
    <p class="text-text-secondary text-sm mb-6">Mountain West (NCAAB) • Moby Arena</p>
    <TeamFullSchedule teamKey="csu_basketball" client:load />
    <p class="text-text-secondary text-sm italic mt-6">There's always next season, and next season starts in November!</p>
  </section>
</Layout>
