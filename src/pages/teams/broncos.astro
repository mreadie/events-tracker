---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="Denver Broncos - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/primary" class="hover:text-secondary">Big 4</a>
      <span class="mx-2">/</span>
      <span class="text-accent">Denver Broncos</span>
    </nav>
    <div class="flex items-center gap-2 sm:gap-3 mb-1 flex-wrap">
      <h1 class="text-xl sm:text-2xl md:text-3xl font-bold text-accent">Denver Broncos</h1>
      <a href="https://www.denverbroncos.com" target="_blank" rel="noopener">
        <img src="https://a.espncdn.com/i/teamlogos/nfl/500/den.png" alt="Denver Broncos logo" class="w-10 h-10 object-contain hover:scale-110 transition-transform" />
      </a>
    </div>
    <p class="text-text-secondary text-sm mb-6">NFL • Empower Field at Mile High</p>
    <TeamFullSchedule teamKey="broncos" seasonStartMonth="September" client:load />
  </section>
</Layout>
