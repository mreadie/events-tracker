---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="DU Pioneers Hockey - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/sports/hockey" class="hover:text-secondary">Hockey</a>
      <span class="mx-2">/</span>
      <span class="text-accent">DU Pioneers</span>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-accent mb-1">DU Pioneers Hockey</h1>
    <p class="text-text-secondary text-sm mb-6">NCHC (NCAA D1) • Magness Arena</p>
    <a href="https://denverpioneers.com/sports/mens-ice-hockey" target="_blank" rel="noopener" class="inline-block mb-6">
      <img src="https://a.espncdn.com/i/teamlogos/ncaa/500/2172.png" alt="DU Pioneers logo" class="w-16 h-16 object-contain hover:scale-110 transition-transform" />
    </a>
    <TeamFullSchedule teamKey="du_hockey" seasonStartMonth="October" client:load />
  </section>
</Layout>
