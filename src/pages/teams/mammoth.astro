---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="Colorado Mammoth - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/secondary" class="hover:text-secondary">All the Rest</a>
      <span class="mx-2">/</span>
      <span class="text-accent">Colorado Mammoth</span>
    </nav>
    <div class="flex items-center gap-2 sm:gap-3 mb-1 flex-wrap">
      <h1 class="text-xl sm:text-2xl md:text-3xl font-bold text-accent">Colorado Mammoth</h1>
      <a href="https://www.coloradomammoth.com" target="_blank" rel="noopener">
        <img src="https://a.espncdn.com/i/teamlogos/nll/500/125422.png" alt="Colorado Mammoth logo" class="w-10 h-10 object-contain hover:scale-110 transition-transform" />
      </a>
    </div>
    <p class="text-text-secondary text-sm mb-6">NLL • Ball Arena</p>
    <TeamFullSchedule teamKey="mammoth" seasonStartMonth="December" client:load />
  </section>
</Layout>
