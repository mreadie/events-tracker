---
import Layout from '../../layouts/Layout.astro';
import TeamFullSchedule from '../../components/TeamFullSchedule.tsx';
---

<Layout title="CU Buffaloes Football - Colorado Sports Events Tracker">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-text-secondary mb-4">
      <a href="/events-tracker/secondary" class="hover:text-secondary">All the Rest</a>
      <span class="mx-2">/</span>
      <span class="text-accent">CU Buffaloes Football</span>
    </nav>
    <h1 class="text-2xl md:text-3xl font-bold text-accent mb-1">CU Buffaloes Football</h1>
    <p class="text-text-secondary text-sm mb-6">Big 12 (NCAAF) • Folsom Field</p>
    <a href="https://cubuffs.com/sports/football" target="_blank" rel="noopener" class="inline-block mb-6">
      <img src="https://a.espncdn.com/i/teamlogos/ncaa/500/38.png" alt="CU Buffaloes logo" class="w-16 h-16 object-contain hover:scale-110 transition-transform" />
    </a>
    <TeamFullSchedule teamKey="cu_football" seasonStartMonth="August" client:load />
  </section>
</Layout>
