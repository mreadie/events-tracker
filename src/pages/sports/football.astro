---
import Layout from '../../layouts/Layout.astro';
import SportSchedule from '../../components/SportSchedule.tsx';

const teams = [
  {
    name: "Denver Broncos",
    league: "NFL",
    level: "Professional",
    venue: "Empower Field at Mile High",
    color: "#FB4F14",
    description: "3-time Super Bowl champions. Colorado's most popular professional sports franchise.",
    season: "September – February",
    teamPage: "/events-tracker/teams/broncos"
  },
  {
    name: "CU Buffaloes Football",
    league: "Big 12",
    level: "NCAA Division I (FBS)",
    venue: "Folsom Field",
    color: "#CFB87C",
    description: "University of Colorado Boulder football. 1990 National Champions. Coach Prime era.",
    season: "August – January",
    teamPage: "/events-tracker/teams/cu-football"
  },
  {
    name: "CSU Rams Football",
    league: "Mountain West",
    level: "NCAA Division I (FBS)",
    venue: "Canvas Stadium",
    color: "#1E4D2B",
    description: "Colorado State University's FBS football program in the Mountain West Conference.",
    season: "August – December",
    teamPage: "/events-tracker/teams/csu-football"
  },
  {
    name: "Air Force Falcons Football",
    league: "Mountain West",
    level: "NCAA Division I (FBS)",
    venue: "Falcon Stadium",
    color: "#003087",
    description: "US Air Force Academy football. Known for their triple-option offense and Commander-in-Chief's Trophy rivalry.",
    season: "August – December",
    teamPage: "/events-tracker/teams/airforce-football"
  }
];
---

<Layout title="Football - Colorado Sports Events Tracker">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-12">
    <div class="mb-10">
      <nav class="text-sm text-text-secondary mb-4">
        <a href="/events-tracker/sports" class="hover:text-secondary">Sports</a> <span class="mx-2">/</span> <span class="text-accent">Football</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-accent mb-3">🏈 Football in Colorado</h1>
      <p class="text-text-secondary text-lg">NFL and Division I college football teams across the state.</p>
    </div>

    <!-- Professional -->
    <h2 class="text-xl font-bold text-accent mb-4 border-b border-secondary/20 pb-2">Professional</h2>
    <div class="grid grid-cols-1 gap-6 mb-10">
      {teams.filter(t => t.level === "Professional").map((team) => (
        <div class="bg-surface-card border border-secondary/20 hover:border-secondary/50 rounded-xl overflow-hidden transition-all">
          <div class="h-2 w-full" style={`background-color: ${team.color}`}></div>
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <a href={team.teamPage}><h3 class="text-xl font-bold text-accent hover:text-secondary hover:underline transition-colors">{team.name}</h3></a>
              <span class="text-xs font-semibold bg-secondary/20 text-secondary px-2 py-1 rounded">{team.league}</span>
            </div>
            <p class="text-text-secondary text-sm mb-4">{team.description}</p>
            <div class="flex justify-between text-sm text-text-secondary">
              <span><span class="font-medium text-text-primary">Venue:</span> {team.venue}</span>
              <span><span class="font-medium text-text-primary">Season:</span> {team.season}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- College -->
    <h2 class="text-xl font-bold text-accent mb-4 border-b border-secondary/20 pb-2">College Football</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {teams.filter(t => t.level !== "Professional").map((team) => (
        <div class="bg-surface-card border border-secondary/20 hover:border-secondary/50 rounded-xl overflow-hidden transition-all">
          <div class="h-2 w-full" style={`background-color: ${team.color}`}></div>
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <a href={team.teamPage}><h3 class="text-lg font-bold text-accent hover:text-secondary hover:underline transition-colors">{team.name}</h3></a>
              <span class="text-xs font-semibold bg-surface-light text-text-secondary px-2 py-1 rounded">{team.league}</span>
            </div>
            <p class="text-text-secondary text-sm mb-3">{team.description}</p>
            <div class="text-sm text-text-secondary">
              <span class="font-medium text-text-primary">Venue:</span> {team.venue}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Live Schedule -->
    <div class="mt-10">
      <h2 class="text-xl font-bold text-accent mb-2 border-b border-secondary/20 pb-2">Live Schedule</h2>
      <SportSchedule teamKeys={["broncos", "cu_football", "csu_football", "airforce_football"]} client:load />
    </div>
  </section>
</Layout>
