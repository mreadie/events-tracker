---
import Layout from '../../layouts/Layout.astro';
import SportSchedule from '../../components/SportSchedule.tsx';

const teams = [
  {
    name: "Colorado Rockies",
    league: "MLB",
    level: "Professional",
    venue: "Coors Field",
    color: "#333366",
    description: "Colorado's MLB franchise playing at the iconic Coors Field in downtown Denver. NL pennant winners in 2007.",
    season: "March – October"
  },
  {
    name: "Northern Colorado Owlz",
    league: "Pioneer League",
    level: "Independent",
    venue: "Jackson Field",
    color: "#1C3F6E",
    description: "Independent minor league baseball in the Pioneer League, based in Windsor, CO.",
    season: "May – September"
  }
];
---

<Layout title="Baseball - Colorado Sports Events Tracker">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <nav class="text-sm text-text-secondary mb-4">
        <a href="/events-tracker/sports" class="hover:text-secondary">Sports</a> <span class="mx-2">/</span> <span class="text-accent">Baseball</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-accent mb-3">⚾ Baseball in Colorado</h1>
      <p class="text-text-secondary text-lg">MLB and independent league baseball in the Centennial State.</p>
    </div>

    <!-- Professional -->
    <h2 class="text-xl font-bold text-accent mb-4 border-b border-secondary/20 pb-2">Major League Baseball</h2>
    <div class="grid grid-cols-1 gap-6 mb-10">
      {teams.filter(t => t.level === "Professional").map((team) => (
        <div class="bg-surface-card border border-secondary/20 hover:border-secondary/50 rounded-xl overflow-hidden transition-all">
          <div class="h-2 w-full" style={`background-color: ${team.color}`}></div>
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <a href="/events-tracker/teams/rockies"><h3 class="text-xl font-bold text-accent hover:text-secondary hover:underline transition-colors">{team.name}</h3></a>
              <span class="text-xs font-semibold bg-secondary/20 text-secondary px-2 py-1 rounded">{team.league}</span>
            </div>
            <p class="text-text-secondary text-sm mb-4">{team.description}</p>
            <div class="flex justify-between text-sm text-text-secondary">
              <span><span class="font-medium text-text-primary">Venue:</span> {team.venue}</span>
              <span><span class="font-medium text-text-primary">Season:</span> {team.season}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Independent -->
    <h2 class="text-xl font-bold text-accent mb-4 border-b border-secondary/20 pb-2">Independent League</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {teams.filter(t => t.level === "Independent").map((team) => (
        <div class="bg-surface-card border border-secondary/20 hover:border-secondary/50 rounded-xl overflow-hidden transition-all">
          <div class="h-2 w-full" style={`background-color: ${team.color}`}></div>
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-lg font-bold text-accent">{team.name}</h3>
              <span class="text-xs font-semibold bg-surface-light text-text-secondary px-2 py-1 rounded">{team.league}</span>
            </div>
            <p class="text-text-secondary text-sm mb-3">{team.description}</p>
            <div class="text-sm text-text-secondary">
              <span class="font-medium text-text-primary">Venue:</span> {team.venue}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Live Schedule -->
    <div class="mt-10">
      <h2 class="text-xl font-bold text-accent mb-2 border-b border-secondary/20 pb-2">Live Schedule</h2>
      <SportSchedule teamKeys={["rockies"]} client:load />
    </div>
  </section>
</Layout>
