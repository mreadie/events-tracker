---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Lacrosse - Colorado Sports Events Tracker">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <nav class="text-sm text-text-secondary mb-4">
        <a href="/sports" class="hover:text-secondary">Sports</a> <span class="mx-2">/</span> <span class="text-accent">Lacrosse</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-accent mb-3">🥍 Lacrosse in Colorado</h1>
      <p class="text-text-secondary text-lg">National Lacrosse League action at Ball Arena.</p>
    </div>

    <!-- Colorado Mammoth -->
    <div class="bg-surface-card border border-secondary/20 rounded-xl overflow-hidden">
      <div class="h-2 w-full" style="background-color: #8B0000"></div>
      <div class="p-8">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h2 class="text-2xl font-bold text-accent">Colorado Mammoth</h2>
            <span class="text-xs font-semibold bg-secondary/20 text-secondary px-2 py-1 rounded mt-2 inline-block">NLL</span>
          </div>
        </div>
        <p class="text-text-secondary mb-6">
          The Colorado Mammoth are Denver's National Lacrosse League team, playing at Ball Arena. 
          Founded in 2003, they are 3-time NLL Champions (2006, 2014, 2022) and one of the most successful franchises in the league.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
          <div class="bg-surface-light rounded-lg p-4">
            <span class="text-text-secondary block mb-1">Venue</span>
            <span class="text-accent font-medium">Ball Arena</span>
          </div>
          <div class="bg-surface-light rounded-lg p-4">
            <span class="text-text-secondary block mb-1">Division</span>
            <span class="text-accent font-medium">West Division</span>
          </div>
          <div class="bg-surface-light rounded-lg p-4">
            <span class="text-text-secondary block mb-1">Season</span>
            <span class="text-accent font-medium">December – May</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
