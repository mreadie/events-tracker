---
import Layout from '../../layouts/Layout.astro';
import SportSchedule from '../../components/SportSchedule.tsx';

const teams = [
  {
    name: "Colorado Avalanche",
    league: "NHL",
    level: "Professional",
    venue: "Ball Arena",
    color: "#6F263D",
    description: "3-time Stanley Cup champions (1996, 2001, 2022). One of the premier NHL franchises.",
    season: "October – June",
    teamPage: "/events-tracker/teams/avalanche"
  },
  {
    name: "Colorado College Tigers",
    league: "NCHC",
    level: "NCAA Division I",
    venue: "Ed Robson Arena",
    color: "#000000",
    description: "Colorado College's NCAA Division I men's hockey program in the NCHC conference.",
    season: "October – March"
  },
  {
    name: "DU Pioneers",
    league: "NCHC",
    level: "NCAA Division I",
    venue: "Magness Arena",
    color: "#8B2332",
    description: "University of Denver's storied hockey program — 9-time NCAA champions.",
    season: "October – March"
  },
  {
    name: "Air Force Falcons Hockey",
    league: "Atlantic Hockey",
    level: "NCAA Division I",
    venue: "Cadet Ice Arena",
    color: "#003087",
    description: "US Air Force Academy's Division I hockey program.",
    season: "October – March"
  }
];
---

<Layout title="Hockey - Colorado Sports Events Tracker">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <nav class="text-sm text-text-secondary mb-4">
        <a href="/events-tracker/sports" class="hover:text-secondary">Sports</a> <span class="mx-2">/</span> <span class="text-accent">Hockey</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold text-accent mb-3">🏒 Hockey in Colorado</h1>
      <p class="text-text-secondary text-lg">From the NHL's Avalanche to top college programs.</p>
    </div>

    <!-- Professional -->
    <h2 class="text-xl font-bold text-accent mb-4 border-b border-secondary/20 pb-2">Professional</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      {teams.filter(t => t.level === "Professional").map((team) => (
        <div class="bg-surface-card border border-secondary/20 hover:border-secondary/50 rounded-xl overflow-hidden transition-all">
          <div class="h-2 w-full" style={`background-color: ${team.color}`}></div>
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <a href={team.teamPage}><h3 class="text-lg font-bold text-accent hover:text-secondary hover:underline transition-colors">{team.name}</h3></a>
              <span class="text-xs font-semibold bg-secondary/20 text-secondary px-2 py-1 rounded">{team.league}</span>
            </div>
            <p class="text-text-secondary text-sm mb-4">{team.description}</p>
            <div class="flex justify-between text-sm text-text-secondary">
              <span><span class="font-medium text-text-primary">Venue:</span> {team.venue}</span>
              <span><span class="font-medium text-text-primary">Season:</span> {team.season}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- College -->
    <h2 class="text-xl font-bold text-accent mb-4 border-b border-secondary/20 pb-2">College Hockey</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {teams.filter(t => t.level === "NCAA Division I").map((team) => (
        <div class="bg-surface-card border border-secondary/20 hover:border-secondary/50 rounded-xl overflow-hidden transition-all">
          <div class="h-2 w-full" style={`background-color: ${team.color}`}></div>
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-lg font-bold text-accent">{team.name}</h3>
              <span class="text-xs font-semibold bg-surface-light text-text-secondary px-2 py-1 rounded">{team.league}</span>
            </div>
            <p class="text-text-secondary text-sm mb-3">{team.description}</p>
            <div class="text-sm text-text-secondary">
              <span class="font-medium text-text-primary">Venue:</span> {team.venue}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Live Schedule -->
    <div class="mt-10">
      <h2 class="text-xl font-bold text-accent mb-2 border-b border-secondary/20 pb-2">Live Schedule</h2>
      <SportSchedule teamKeys={["avalanche"]} client:load />
    </div>
  </section>
</Layout>
