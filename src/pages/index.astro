---
import Layout from '../layouts/Layout.astro';
import ActiveSchedule from '../components/ActiveSchedule.tsx';
import RedRocksConcerts from '../components/RedRocksConcerts.tsx';
---

<Layout title="Colorado Sports and Music">
  <!-- Full-page background image -->
  <div class="relative min-h-[calc(100vh-3rem)]">
    <!-- Background image fixed behind all content -->
    <div class="absolute inset-0">
      <img src="/events-tracker/images/CoorsFieldSunset.jpg" alt="Coors Field sunset" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-surface/70"></div>
    </div>

    <!-- All content on top of the image -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col gap-6">
      <!-- Hero Text -->
      <div class="text-center">
        <h1 class="text-2xl sm:text-3xl md:text-5xl font-extrabold text-accent mb-2 tracking-tight drop-shadow-lg">
          Colorado Sports and Music
        </h1>
        <p class="text-base text-text-secondary max-w-2xl mx-auto mb-3 drop-shadow">
          Your guide to games, scores, and schedules for every Colorado sports team and major concert venue.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/events-tracker/primary" class="bg-secondary hover:bg-secondary/90 hover:scale-105 text-white font-semibold px-5 py-2 rounded-lg transition-all shadow-lg shadow-secondary/20">
            Big 4
          </a>
          <a href="/events-tracker/secondary" class="border border-secondary text-secondary hover:bg-secondary/10 hover:scale-105 font-semibold px-5 py-2 rounded-lg transition-all backdrop-blur-sm">
            All the Rest
          </a>
          <a href="/events-tracker/music" class="bg-red-700 hover:bg-red-600 hover:scale-105 text-white font-semibold px-5 py-2 rounded-lg transition-all shadow-lg shadow-red-700/20">
            Shows
          </a>
        </div>
      </div>

      <!-- Active Seasons -->
      <div>
        <ActiveSchedule client:load />
        <div class="mt-3">
          <RedRocksConcerts client:load />
        </div>
      </div>

      <!-- Browse by Sport -->
      <div>
        <h2 class="text-lg font-bold text-accent mb-3 text-center drop-shadow">Browse by Sport</h2>
        <div class="grid grid-cols-3 sm:grid-cols-5 gap-3">
          <a href="/events-tracker/sports/football" class="bg-surface-card/40 backdrop-blur-md hover:bg-surface-card/70 border border-white/10 hover:border-secondary/50 rounded-xl p-3 text-center transition-all hover:scale-105 hover:shadow-lg hover:shadow-secondary/10">
            <div class="text-2xl mb-1">🏈</div>
            <span class="text-text-primary font-medium text-xs">Football</span>
          </a>
          <a href="/events-tracker/sports/basketball" class="bg-surface-card/40 backdrop-blur-md hover:bg-surface-card/70 border border-white/10 hover:border-secondary/50 rounded-xl p-3 text-center transition-all hover:scale-105 hover:shadow-lg hover:shadow-secondary/10">
            <div class="text-2xl mb-1">🏀</div>
            <span class="text-text-primary font-medium text-xs">Basketball</span>
          </a>
          <a href="/events-tracker/sports/hockey" class="bg-surface-card/40 backdrop-blur-md hover:bg-surface-card/70 border border-white/10 hover:border-secondary/50 rounded-xl p-3 text-center transition-all hover:scale-105 hover:shadow-lg hover:shadow-secondary/10">
            <div class="text-2xl mb-1">🏒</div>
            <span class="text-text-primary font-medium text-xs">Hockey</span>
          </a>
          <a href="/events-tracker/sports/baseball" class="bg-surface-card/40 backdrop-blur-md hover:bg-surface-card/70 border border-white/10 hover:border-secondary/50 rounded-xl p-3 text-center transition-all hover:scale-105 hover:shadow-lg hover:shadow-secondary/10">
            <div class="text-2xl mb-1">⚾</div>
            <span class="text-text-primary font-medium text-xs">Baseball</span>
          </a>
          <a href="/events-tracker/sports/soccer" class="bg-surface-card/40 backdrop-blur-md hover:bg-surface-card/70 border border-white/10 hover:border-secondary/50 rounded-xl p-3 text-center transition-all hover:scale-105 hover:shadow-lg hover:shadow-secondary/10">
            <div class="text-2xl mb-1">⚽</div>
            <span class="text-text-primary font-medium text-xs">Soccer</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
